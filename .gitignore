# Secrets — NEVER commit
# Convention: underscore-prefixed _config.php contains credentials.
# Non-underscored config.php files (like api/reminders/config.php) are
# application code and ARE tracked.
api/_config.php
**/_config.php
**/*.env
**/*.env.*

# macOS
.DS_Store
._*

# Microsoft Office lock files
~$*

# Editor backups / temp files
.bak-*
.tmp-*
*.bak
*.swp
*.swo
*~

# Logs
*.log
logs/

# PHP opcache
.opcache/

# Node (if ever added)
node_modules/

# OS junk
Thumbs.db

# Built artifacts
*.zip
*.tar.gz

# Ionos automatic upload metadata
.ftpquota

# Claude Code per-developer config
.clauderc
.claude/

# Working notes (private, not shared)
notes/

# Archived / Dropbox-style staging folders (superseded by apps/strength-index/)
RSSI App/
Relicheck Studio Web-App/

# Ephemeral drafts (not long-lived references)
Marketing homepage rewrite.docx
ReliCheck feedback 2.docx

# Studio reference screenshots (not embedded in product or docs)
360 Studio.png
MM Studio.png
Strength Survey Studio.png
Survey Studio.png
TIA Studio.png
